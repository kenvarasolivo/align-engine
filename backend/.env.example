# Copy to backend/.env and fill in your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase (https://supabase.com/dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: max Gemini analyses per signed-in user per day (default 20)
DAILY_ANALYSIS_LIMIT=20

# RAG / Skill Coach: the pgvector knowledge base reuses the keys above —
# GEMINI_API_KEY for gemini-embedding-001 embeddings and the SUPABASE_* keys for
# pgvector storage/retrieval. No extra config needed; just run the schema and
# `python -m scripts.ingest_kb` to populate it.
