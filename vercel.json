{
  "rewrites": [{ "source": "/app/:path*", "destination": "/index.html" }],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "framework": "fastapi"
    }
  }
}
